{
  "name": "posthog-cli",
  "version": "0.1.1",
  "description": "PostHog CLI — manage PostHog projects from the terminal",
  "author": "sapihav",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sapihav/poshog-cli.git"
  },
  "keywords": [
    "posthog",
    "cli",
    "analytics",
    "feature-flags",
    "experiments"
  ],
  "bin": {
    "posthog": "dist/index.js"
  },
  "files": [
    "dist/**/*.js"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "tsx --test test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
